<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SSRA Customs · Inspection Report</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <link href="../assets/icons/remixicon.css" rel="stylesheet" />
    <style>
        .gradient-bg { background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%); }
        .tab-btn { padding: 0.75rem 1.5rem; border-bottom: 3px solid transparent; font-weight: 500; cursor: pointer; transition: all 0.2s; color: #6b7280; }
        .tab-btn.active { border-bottom-color: #7c3aed; color: #7c3aed; }
        .section-card { border-left: 4px solid #7c3aed; background: #f5f3ff; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1rem; }
        .info-row { display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #e5e7eb; }
        .info-row:last-child { border-bottom: none; }
        .badge { display: inline-block; padding: 0.3rem 0.8rem; border-radius: 9999px; font-size: 0.85rem; font-weight: 600; }
        .badge-pending { background: #fef3c7; color: #92400e; }
        .badge-inspecting { background: #dbeafe; color: #1e40af; }
        .badge-completed { background: #d1fae5; color: #065f46; }
        .doc-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; background: white; border: 1px solid #e5e7eb; border-radius: 0.5rem; margin-bottom: 0.5rem; }
        .doc-icon { width: 2.5rem; height: 2.5rem; background: #ede9fe; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; color: #7c3aed; }
        .photo-item { position: relative; display: inline-block; margin: 0.5rem; }
        .photo-item img { width: 120px; height: 120px; object-fit: cover; border-radius: 0.5rem; border: 2px solid #e5e7eb; }
        .photo-item .remove-btn { position: absolute; top: -8px; right: -8px; background: #ef4444; color: white; border: none; border-radius: 50%; width: 24px; height: 24px; cursor: pointer; display: flex; align-items: center; justify-content: center; }
        .finding-item { padding: 0.75rem; border-left: 3px solid #7c3aed; background: #f5f3ff; margin-bottom: 0.5rem; border-radius: 0.3rem; }
        .action-btn { padding: 0.6rem 1.5rem; border-radius: 0.5rem; font-weight: 600; transition: all 0.2s; font-size: 0.9rem; }
        .btn-submit { background: #10b981; color: white; }
        .btn-submit:hover { background: #059669; }
        .btn-camera { background: #7c3aed; color: white; }
        .btn-camera:hover { background: #6d28d9; }
        textarea { width: 100%; padding: 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem; font-family: inherit; resize: vertical; }
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 50; }
        .modal-overlay.open { display: flex; align-items: center; justify-content: center; }
        .modal-content { background: white; border-radius: 1rem; padding: 2rem; max-width: 600px; width: 90%; box-shadow: 0 20px 25px rgba(0,0,0,0.15); }
        .modal-title { font-size: 1.5rem; font-weight: bold; margin-bottom: 1rem; color: #1f2937; }
        video { width: 100%; border-radius: 0.5rem; margin: 1rem 0; background: #000; }
        .status-badge-large { padding: 0.5rem 1rem; border-radius: 0.75rem; font-weight: 600; display: inline-block; }
        .status-inspecting { background: #dbeafe; color: #1e40af; }
        .workflow-step { display: flex; gap: 0.75rem; padding: 0.9rem; border: 1px solid #e5e7eb; border-radius: 0.75rem; background: #fff; }
        .workflow-step-icon { width: 2.25rem; height: 2.25rem; border-radius: 9999px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .routing-card { border: 1px solid rgba(255,255,255,0.16); background: rgba(255,255,255,0.1); border-radius: 0.75rem; padding: 1rem; }
    </style>
</head>
<body>
    <div class="min-h-screen bg-gray-100">
        <div class="max-w-7xl mx-auto px-4 py-5">
            <div class="flex flex-col lg:flex-row gap-6">
                <aside class="lg:w-72 flex-shrink-0">
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-200/70 p-5 sticky top-6">
                        <div class="text-center mb-5">
                            <div class="w-20 h-20 rounded-2xl flex items-center justify-center mx-auto mb-2 shadow-md gradient-bg">
                                <i class="ri-user-line text-white text-3xl"></i>
                            </div>
                            <h3 id="profileName" class="text-lg font-bold text-gray-800">Loading...</h3>
                            <p id="profileRole" class="text-gray-500 text-sm">Loading...</p>
                            <span class="inline-block mt-1 text-xs bg-green-100 text-green-700 px-2.5 py-0.5 rounded-full font-medium">● Active</span>
                        </div>
                        <nav class="space-y-1 mb-4">
                            <a href="dashboard-inspector.html" class="sidebar-link"><i class="ri-dashboard-line"></i><span>Dashboard</span></a>
                            <a href="inspection-queue.html" class="sidebar-link"><i class="ri-clipboard-line"></i><span>Queue</span></a>
                            <a href="inspection-reports.html" class="sidebar-link"><i class="ri-file-chart-line"></i><span>Reports</span></a>
                            <a href="notifications.html" class="sidebar-link"><i class="ri-notification-3-line"></i><span>Notifications</span></a>
                        </nav>
                        <button id="signOutBtn" class="mt-4 w-full bg-red-50 text-red-600 py-2.5 rounded-xl text-sm font-semibold hover:bg-red-100 transition flex items-center justify-center gap-2">
                            <i class="ri-logout-box-line"></i> Sign Out
                        </button>
                    </div>
                </aside>

                <main class="flex-1 space-y-5">
                    <div class="gradient-bg rounded-2xl p-5 text-white shadow-lg">
                        <div class="flex items-start justify-between gap-4 mb-4">
                            <div>
                                <h2 class="text-3xl font-bold tracking-tight">🔍 Physical Inspection</h2>
                                <p class="opacity-90 text-sm mt-1" id="headerAppNumber">Application Loading...</p>
                            </div>
                            <a href="inspection-queue.html" class="bg-white/20 hover:bg-white/30 px-4 py-2 rounded-lg text-sm font-semibold transition flex items-center gap-2">
                                <i class="ri-arrow-left-line"></i> Back
                            </a>
                        </div>
                        <div class="flex flex-wrap gap-3">
                            <span class="badge badge-inspecting">In Progress</span>
                            <span class="badge badge-pending">Auto-assigned by Workflow Engine</span>
                            <span class="text-sm opacity-90" id="startDateDisplay">Started: Loading...</span>
                            <span class="text-sm opacity-90" id="inspectorNameDisplay">Inspector: Loading...</span>
                        </div>
                    </div>

                    <!-- Tab Navigation -->
                    <div class="bg-white rounded-xl border border-gray-200 shadow-sm flex overflow-x-auto" id="tabNavigation">
                        <button class="tab-btn active" data-tab="overview">Overview</button>
                        <button class="tab-btn" data-tab="inspection">Inspection</button>
                        <button class="tab-btn" data-tab="photographs">Photographs</button>
                        <button class="tab-btn" data-tab="findings">Findings</button>
                    </div>

                    <!-- OVERVIEW TAB -->
                    <div id="tab-overview" class="space-y-4">
                        <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                            <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-5">
                                <div>
                                    <h3 class="font-bold text-lg">Inspector Review Workflow</h3>
                                    <p class="text-sm text-gray-600 mt-1">This application was assigned automatically because physical inspection is required.</p>
                                </div>
                                <span class="status-badge-large status-inspecting">Inspector Review</span>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-5">
                                <div class="workflow-step">
                                    <div class="workflow-step-icon bg-blue-100 text-blue-700"><i class="ri-route-line"></i></div>
                                    <div>
                                        <p class="font-semibold text-gray-900 text-sm">Automatic assignment</p>
                                        <p class="text-xs text-gray-600 mt-1">The workflow engine sends inspection-required applications to an Inspector queue.</p>
                                    </div>
                                </div>
                                <div class="workflow-step">
                                    <div class="workflow-step-icon bg-amber-100 text-amber-700"><i class="ri-search-eye-line"></i></div>
                                    <div>
                                        <p class="font-semibold text-gray-900 text-sm">Physical inspection</p>
                                        <p class="text-xs text-gray-600 mt-1">Inspect the goods, verify the declaration, and record field observations.</p>
                                    </div>
                                </div>
                                <div class="workflow-step">
                                    <div class="workflow-step-icon bg-purple-100 text-purple-700"><i class="ri-camera-line"></i></div>
                                    <div>
                                        <p class="font-semibold text-gray-900 text-sm">Evidence and report</p>
                                        <p class="text-xs text-gray-600 mt-1">Attach photographs if required, enter findings, and upload the inspection report.</p>
                                    </div>
                                </div>
                                <div class="workflow-step">
                                    <div class="workflow-step-icon bg-emerald-100 text-emerald-700"><i class="ri-brain-line"></i></div>
                                    <div>
                                        <p class="font-semibold text-gray-900 text-sm">AI validation</p>
                                        <p class="text-xs text-gray-600 mt-1">AI checks the report against declared goods, findings, and supporting evidence.</p>
                                    </div>
                                </div>
                            </div>

                            <div class="bg-[#0f2b44] text-white rounded-xl p-5">
                                <div class="flex items-center justify-between gap-3 mb-4">
                                    <h4 class="font-bold">Automatic routing after submission</h4>
                                    <i class="ri-git-branch-line text-2xl text-emerald-300"></i>
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                    <div class="routing-card">
                                        <p class="text-sm font-semibold text-amber-200">Inconsistencies detected</p>
                                        <p class="text-xs text-white/80 mt-1">Application is returned for correction with AI validation issues and inspection findings attached.</p>
                                    </div>
                                    <div class="routing-card">
                                        <p class="text-sm font-semibold text-emerald-200">Report validated</p>
                                        <p class="text-xs text-white/80 mt-1">Application proceeds to the Supervisor for the next review stage.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                            <h3 class="font-bold text-lg mb-4">Application Details</h3>
                            <div class="info-row">
                                <span class="text-gray-600">Application Number</span>
                                <span class="font-semibold text-blue-600" id="applicationNumber">Loading...</span>
                            </div>
                            <div class="info-row">
                                <span class="text-gray-600">Trader</span>
                                <span class="font-semibold" id="traderName">Loading...</span>
                            </div>
                            <div class="info-row">
                                <span class="text-gray-600">Application Type</span>
                                <span class="font-semibold" id="applicationType">Loading...</span>
                            </div>
                            <div class="info-row">
                                <span class="text-gray-600">Declared Value</span>
                                <span class="font-semibold text-green-600" id="declaredValue">Loading...</span>
                            </div>
                            <div class="info-row">
                                <span class="text-gray-600">Port of Entry</span>
                                <span class="font-semibold" id="portOfEntry">Loading...</span>
                            </div>
                        </div>

                        <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                            <h3 class="font-bold text-lg mb-4">Goods Information</h3>
                            <div class="info-row">
                                <span class="text-gray-600">Product Description</span>
                                <span class="font-semibold" id="productDescription">Loading...</span>
                            </div>
                            <div class="info-row">
                                <span class="text-gray-600">HS Code</span>
                                <span class="font-semibold" id="hsCode">Loading...</span>
                            </div>
                            <div class="info-row">
                                <span class="text-gray-600">Quantity</span>
                                <span class="font-semibold" id="quantity">Loading...</span>
                            </div>
                            <div class="info-row">
                                <span class="text-gray-600">Origin Country</span>
                                <span class="font-semibold" id="originCountry">Loading...</span>
                            </div>
                            <div class="info-row">
                                <span class="text-gray-600">Condition</span>
                                <span class="font-semibold" id="condition">Loading...</span>
                            </div>
                        </div>

                        <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                            <h3 class="font-bold text-lg mb-4">📁 Supporting Documents</h3>
                            <div id="documentsContainer">
                                <div class="text-sm text-gray-500 text-center py-4">Loading documents...</div>
                            </div>
                        </div>
                    </div>

                    <!-- INSPECTION TAB -->
                    <div id="tab-inspection" class="space-y-4" style="display: none;">
                        <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                            <h3 class="font-bold text-lg mb-4">📋 Inspection Checklist</h3>
                            
                            <div class="space-y-3 mb-6">
                                <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="checkbox" class="w-5 h-5 text-purple-600" />
                                    <span class="text-sm font-medium text-gray-700">Physical goods match declared description</span>
                                </label>

                                <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="checkbox" class="w-5 h-5 text-purple-600" />
                                    <span class="text-sm font-medium text-gray-700">Quantity verified and matches declaration</span>
                                </label>

                                <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="checkbox" class="w-5 h-5 text-purple-600" />
                                    <span class="text-sm font-medium text-gray-700">Goods condition acceptable (no damage)</span>
                                </label>

                                <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="checkbox" class="w-5 h-5 text-purple-600" />
                                    <span class="text-sm font-medium text-gray-700">Serial numbers/marks verified</span>
                                </label>

                                <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="checkbox" class="w-5 h-5 text-purple-600" />
                                    <span class="text-sm font-medium text-gray-700">Packaging intact and secure</span>
                                </label>

                                <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="checkbox" class="w-5 h-5 text-purple-600" />
                                    <span class="text-sm font-medium text-gray-700">No prohibited or restricted items detected</span>
                                </label>

                                <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="checkbox" class="w-5 h-5 text-purple-600" />
                                    <span class="text-sm font-medium text-gray-700">Weight/volume measurements recorded</span>
                                </label>

                                <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="checkbox" class="w-5 h-5 text-purple-600" />
                                    <span class="text-sm font-medium text-gray-700">All markings and labels verified</span>
                                </label>
                            </div>

                            <div class="border-t pt-6">
                                <h4 class="font-semibold mb-3">Inspection Notes</h4>
                                <textarea placeholder="Record your detailed inspection findings here..." rows="5"></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- PHOTOGRAPHS TAB -->
                    <div id="tab-photographs" class="space-y-4" style="display: none;">
                        <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                            <h3 class="font-bold text-lg mb-4">📸 Inspection Photographs</h3>
                            
                            <button class="action-btn btn-camera mb-6" id="cameraBtn">
                                <i class="ri-camera-line"></i> Take Photo
                            </button>

                            <div class="bg-gray-50 p-6 rounded-lg border-2 border-dashed border-gray-300 text-center mb-6">
                                <p class="text-sm text-gray-600 mb-3">Or drag photos here to upload</p>
                                <input type="file" id="photoInput" multiple accept="image/*" style="display: none;" />
                                <button class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition" id="selectPhotosBtn">
                                    Select Photos
                                </button>
                                <p class="text-xs text-gray-500 mt-2">JPG, PNG up to 10MB each</p>
                            </div>

                            <div id="photoGallery" class="flex flex-wrap gap-2 min-h-[120px] bg-gray-50 p-4 rounded-lg">
                                <p class="text-sm text-gray-500 w-full">Photos will appear here</p>
                            </div>
                        </div>
                    </div>

                    <!-- FINDINGS TAB -->
                    <div id="tab-findings" class="space-y-4" style="display: none;">
                        <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                            <h3 class="font-bold text-lg mb-4">🎯 Inspection Findings</h3>

                            <div class="mb-6">
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Overall Inspection Result</label>
                                <div class="space-y-2">
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="radio" name="result" value="passed" class="w-4 h-4 text-green-600" />
                                        <span class="text-sm text-gray-700"><strong>✓ Passed</strong> - Goods verified, no discrepancies</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="radio" name="result" value="failed" class="w-4 h-4 text-red-600" />
                                        <span class="text-sm text-gray-700"><strong>✗ Failed</strong> - Discrepancies detected, requires further action</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="radio" name="result" value="conditional" class="w-4 h-4 text-amber-600" />
                                        <span class="text-sm text-gray-700"><strong>⚠ Conditional Pass</strong> - Minor issues requiring correction</span>
                                    </label>
                                </div>
                            </div>

                            <div class="mb-6">
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Discrepancies Found (if any)</label>
                                <textarea id="discrepancies" placeholder="Describe any discrepancies between declared and actual goods..." rows="4"></textarea>
                            </div>

                            <div class="mb-6">
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Recommendations</label>
                                <textarea id="recommendations" placeholder="Provide your recommendation. Valid reports proceed to Supervisor; inconsistent reports are returned for correction." rows="4"></textarea>
                            </div>

                            <div class="mb-6">
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" id="samplesRequired" class="w-5 h-5 text-purple-600" />
                                    <span class="text-sm font-semibold text-gray-700">Physical samples required for laboratory analysis</span>
                                </label>
                            </div>

                            <div class="mb-6">
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Laboratory Test Required</label>
                                <select id="labTest" class="w-full p-2 border border-gray-300 rounded-lg">
                                    <option value="none">None</option>
                                    <option value="quality">Quality Analysis</option>
                                    <option value="composition">Material Composition</option>
                                    <option value="hazmat">Hazardous Material Test</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- SUBMIT BUTTON -->
                    <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                        <div class="mb-4 p-4 rounded-lg bg-emerald-50 border border-emerald-200 text-sm text-emerald-900">
                            <strong>Submit workflow:</strong> Uploads the inspection report, starts AI validation, then automatically returns the application for correction if inconsistencies are found or routes it to the Supervisor if validated.
                        </div>
                        <div class="flex flex-col sm:flex-row gap-3">
                            <button class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-800 py-2 rounded-lg font-semibold transition" id="saveDraftBtn">
                                Save as Draft
                            </button>
                            <button class="flex-1 action-btn btn-submit" id="submitBtn">
                                <i class="ri-check-line"></i> Submit Inspection Report
                            </button>
                        </div>
                    </div>
                </main>
            </div>
        </div>
    </div>

    <!-- CAMERA MODAL -->
    <div id="cameraModal" class="modal-overlay">
        <div class="modal-content">
            <h2 class="modal-title">📸 Take Inspection Photo</h2>
            <video id="videoStream" width="100%"></video>
            <canvas id="photoCanvas" style="display: none;"></canvas>
            <div class="flex gap-3">
                <button class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-800 py-2 rounded-lg font-semibold transition" id="closeCameraBtn">Cancel</button>
                <button class="flex-1 action-btn btn-camera" id="capturePhotoBtn">Capture Photo</button>
            </div>
        </div>
    </div>

    <script type="module">
        import supabase from '../../js/supabase.js';
        import { loadCurrentUserProfile } from '../../js/profile-loader.js';
        import { checkPageAuth } from '../../js/auth-check.js';
        
        import { fetchApplicationById, updateApplication, logInspectionActivity, logAuditAction } from '../../js/applications.js';
        
        import { validateInspectionReport, updateApplicationStatusAfterInspection } from '../../js/ai-validation.js';
        
        import { sendInspectionCompletedNotification, sendInspectionEscalatedNotification } from '../../js/notifications.js';

        import { createEscalationCase } from '../../js/escalation-service.js';
        
        import { signOut as authSignOut } from '../../js/auth.js';
        
        import { realtimeManager } from '../../js/realtime.js';

        
        const urlParams = new URLSearchParams(window.location.search);
        let appId = urlParams.get('id');
        let application = null;
        let photos = [];
        let stream = null;
        const PAGE_KEY = 'inspection-details';

        async function init() {
            const hasAuth = await checkPageAuth('inspector');

        // Load user profile
        await loadCurrentUserProfile();
            if (!hasAuth) return;

            if (!appId) {
                // Fetch the first under_inspection application if no id is provided
                const { data: apps } = await supabase
                    .from('applications')
                    .select('id')
                    .eq('status', 'under_inspection')
                    .limit(1);
                if (apps && apps.length > 0) {
                    appId = apps[0].id;
                    window.history.replaceState({}, '', `?id=${appId}`);
                }
            }

            if (appId) {
                const result = await fetchApplicationById(appId);
                if (result.success && result.data) {
                    application = result.data;
                    populateDetails(application);
                    await loadDocuments(appId);
                } else {
                    console.error('Failed to load application details:', result.error);
                }
            }

            await initializeRealtime();

            // Set up event listeners
            document.getElementById('signOutBtn')?.addEventListener('click', handleSignOut);
            document.getElementById('tabNavigation')?.addEventListener('click', (e) => {
                if (e.target.classList.contains('tab-btn')) {
                    const tabName = e.target.getAttribute('data-tab');
                    if (tabName) switchTab(tabName);
                }
            });
            document.getElementById('cameraBtn')?.addEventListener('click', openCameraModal);
            document.getElementById('closeCameraBtn')?.addEventListener('click', closeCameraModal);
            document.getElementById('capturePhotoBtn')?.addEventListener('click', capturePhoto);
            document.getElementById('selectPhotosBtn')?.addEventListener('click', () => {
                document.getElementById('photoInput').click();
            });
            document.getElementById('cameraModal')?.addEventListener('click', (e) => {
                if (e.target.id === 'cameraModal') closeCameraModal();
            });
            document.getElementById('submitBtn')?.addEventListener('click', submitInspectionReport);
            document.getElementById('photoGallery')?.addEventListener('click', (e) => {
                if (e.target.classList.contains('remove-btn') || e.target.closest('.remove-btn')) {
                    const btn = e.target.classList.contains('remove-btn') ? e.target : e.target.closest('.remove-btn');
                    const index = parseInt(btn.getAttribute('data-photo-index'));
                    if (!isNaN(index)) removePhoto(index);
                }
            });
        }

        async function handleSignOut() {
            realtimeManager.unregisterPage(PAGE_KEY);
            const result = await authSignOut();
            if (result.success) {
                window.location.href = '../../auth/login.html';
            } else {
                console.error('Sign out failed:', result.error);
            }
        }

        async function loadDocuments(applicationId) {
            const container = document.getElementById('documentsContainer');
            if (!container) return;

            const { data: documents, error } = await supabase
                .from('documents')
                .select('*')
                .eq('application_id', applicationId)
                .order('created_at', { ascending: false });

            if (error) {
                container.innerHTML = '<div class="text-sm text-gray-500 text-center py-4">Error loading documents</div>';
                return;
            }

            if (!documents || documents.length === 0) {
                container.innerHTML = '<div class="text-sm text-gray-500 text-center py-4">No documents uploaded</div>';
                return;
            }

            container.innerHTML = documents.map(doc => `
                <div class="doc-item">
                    <div class="doc-icon"><i class="ri-file-${getDocumentIcon(doc.document_type)}-line"></i></div>
                    <div class="flex-1">
                        <p class="font-semibold text-sm">${doc.document_name || 'Document'}</p>
                        <p class="text-xs text-gray-500">${formatDocumentType(doc.document_type)} · ${formatFileSize(doc.file_size || 0)}</p>
                    </div>
                </div>
            `).join('');
        }

        function getDocumentIcon(type) {
            const iconMap = {
                'packing_list': 'list',
                'bill_of_lading': 'ship',
                'certificate_of_origin': 'award',
                'invoice': 'money-dollar-circle',
                'insurance': 'shield-check',
                'permit': 'file-text'
            };
            return iconMap[type] || 'file';
        }

        function formatDocumentType(type) {
            return type?.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) || 'Document';
        }

        function formatFileSize(bytes) {
            if (!bytes) return 'Unknown size';
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
            return (bytes / 1048576).toFixed(1) + ' MB';
        }

        async function initializeRealtime() {
            await realtimeManager.initialize();
            
            
            const profile = user ? await supabase.from('profiles').select('*').eq('user_id', user.id).single() : null;
            const userId = profile?.data?.id;
            const role = profile?.data?.role;

            realtimeManager.registerPage(PAGE_KEY, role, userId, {
                onApplicationChange: async (payload) => {
                    if (appId && payload.new?.id === appId) {
                        const result = await fetchApplicationById(appId);
                        if (result.success && result.data) {
                            application = result.data;
                            populateDetails(application);
                        }
                    }
                },
                onDocumentChange: async () => {
                    if (appId) {
                        await loadDocuments(appId);
                    }
                }
            });
        }

        window.addEventListener('beforeunload', () => {
            realtimeManager.unregisterPage(PAGE_KEY);
        });

        function populateDetails(app) {
            // Update Title/Header
            document.querySelectorAll('.text-3xl.font-bold').forEach(el => {
                el.innerHTML = `🔍 Physical Inspection`;
            });
            const headerAppNumber = document.getElementById('headerAppNumber');
            if (headerAppNumber) headerAppNumber.textContent = `Application ${app.application_number || 'Loading...'}`;

            // Date
            const dateEl = document.getElementById('startDateDisplay');
            if (dateEl) dateEl.textContent = `Started: ${new Date(app.created_at).toLocaleString()}`;

            // Populate inspector name and trader name in parallel (N+1 fix)
            Promise.all([
                app.inspector_id ? supabase.from('profiles').select('full_name').eq('id', app.inspector_id).single() : Promise.resolve({ data: null }),
                app.user_id ? supabase.from('profiles').select('full_name').eq('id', app.user_id).single() : Promise.resolve({ data: null })
            ]).then(([inspectorResult, traderResult]) => {
                if (inspectorResult.data && inspectorResult.data.full_name) {
                    const inspectorEl = document.getElementById('inspectorNameDisplay');
                    if (inspectorEl) inspectorEl.textContent = `Inspector: ${inspectorResult.data.full_name}`;
                    const sidebarName = document.querySelector('.text-lg.font-bold');
                    if (sidebarName) sidebarName.textContent = inspectorResult.data.full_name;
                }

                const traderNameEl = document.getElementById('traderName');
                if (traderNameEl) {
                    if (traderResult.data && traderResult.data.full_name) {
                        traderNameEl.textContent = traderResult.data.full_name;
                    } else {
                        traderNameEl.textContent = 'Unknown';
                    }
                }
            });

            // Overview Details using IDs
            const appNumberEl = document.getElementById('applicationNumber');
            if (appNumberEl) appNumberEl.textContent = app.application_number || 'N/A';

            const appTypeEl = document.getElementById('applicationType');
            if (appTypeEl) appTypeEl.textContent = (app.application_type || '').replace('_', ' ').toUpperCase() || 'N/A';

            const declaredValueEl = document.getElementById('declaredValue');
            if (declaredValueEl) declaredValueEl.textContent = `$${(app.declared_value || 0).toLocaleString()} USD`;

            const portOfEntryEl = document.getElementById('portOfEntry');
            if (portOfEntryEl) portOfEntryEl.textContent = app.declaration_data?.port_of_entry || app.goods_data?.location || 'N/A';

            // Goods Info using IDs
            const productDescEl = document.getElementById('productDescription');
            if (productDescEl) productDescEl.textContent = app.goods_data?.item_description || app.declaration_data?.product_description || 'N/A';

            const hsCodeEl = document.getElementById('hsCode');
            if (hsCodeEl) hsCodeEl.textContent = app.goods_data?.hs_code || app.declaration_data?.hs_code || 'N/A';

            const quantityEl = document.getElementById('quantity');
            if (quantityEl) quantityEl.textContent = app.goods_data?.quantity || app.declaration_data?.quantity || 'N/A';

            const originCountryEl = document.getElementById('originCountry');
            if (originCountryEl) originCountryEl.textContent = app.goods_data?.origin_country || app.declaration_data?.origin_country || 'N/A';

            const conditionEl = document.getElementById('condition');
            if (conditionEl) {
                const condition = app.goods_data?.condition || 'New';
                conditionEl.textContent = condition;
                conditionEl.className = 'font-semibold ' + (condition.toLowerCase() === 'used' ? 'text-amber-600' : 'text-green-600');
            }
        }

        function switchTab(tabName) {
            const tabs = document.querySelectorAll('[id^="tab-"]');
            tabs.forEach(tab => tab.style.display = 'none');

            const buttons = document.querySelectorAll('.tab-btn');
            buttons.forEach(btn => btn.classList.remove('active'));

            document.getElementById('tab-' + tabName).style.display = 'block';
            const activeBtn = document.querySelector(`.tab-btn[data-tab="${tabName}"]`);
            if (activeBtn) activeBtn.classList.add('active');
        }

        function openCameraModal() {
            document.getElementById('cameraModal').classList.add('open');
            startCamera();
        }

        function closeCameraModal() {
            document.getElementById('cameraModal').classList.remove('open');
            stopCamera();
        }

        async function startCamera() {
            try {
                stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
                document.getElementById('videoStream').srcObject = stream;
            } catch (err) {
                console.error('Unable to access camera:', err.message);
            }
        }

        function stopCamera() {
            if (stream) {
                stream.getTracks().forEach(track => track.stop());
            }
        }

        function capturePhoto() {
            const video = document.getElementById('videoStream');
            const canvas = document.getElementById('photoCanvas');
            const ctx = canvas.getContext('2d');
            
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            ctx.drawImage(video, 0, 0);
            
            canvas.toBlob(blob => {
                const url = URL.createObjectURL(blob);
                photos.push(url);
                displayPhotos();
                closeCameraModal();
            });
        }

        function handlePhotoUpload(event) {
            const files = event.target.files;
            for (let file of files) {
                const url = URL.createObjectURL(file);
                photos.push(url);
            }
            displayPhotos();
        }

        function displayPhotos() {
            const gallery = document.getElementById('photoGallery');
            if (photos.length === 0) {
                gallery.innerHTML = '<p class="text-sm text-gray-500 w-full">Photos will appear here</p>';
                return;
            }

            gallery.innerHTML = photos.map((url, index) => `
                <div class="photo-item">
                    <img src="${url}" alt="Inspection photo ${index + 1}">
                    <button class="remove-btn" data-photo-index="${index}"><i class="ri-close-line"></i></button>
                </div>
            `).join('');
        }

        function removePhoto(index) {
            photos.splice(index, 1);
            displayPhotos();
        }

        async function submitInspectionReport() {
            console.log("STEP 1: Submit Inspection Report button clicked");
            if (!appId) return;

            const result = document.querySelector('input[name="result"]:checked');
            if (!result) {
                console.error('Please select an inspection result');
                return;
            }

            const checklistItems = document.querySelectorAll('#tab-inspection input[type="checkbox"]');
            const checklist = {
                descriptionMatch: checklistItems[0]?.checked || false,
                quantityVerified: checklistItems[1]?.checked || false,
                conditionAcceptable: checklistItems[2]?.checked || false,
                serialsVerified: checklistItems[3]?.checked || false,
                packagingSecure: checklistItems[4]?.checked || false,
                noProhibited: checklistItems[5]?.checked || false,
                measurementsRecorded: checklistItems[6]?.checked || false,
                labelsVerified: checklistItems[7]?.checked || false
            };

            const discrepancies = document.getElementById('discrepancies').value.trim();
            const recommendations = document.getElementById('recommendations').value.trim();
            const samplesRequired = document.getElementById('samplesRequired')?.checked || false;
            const labTest = document.getElementById('labTest')?.value || 'none';

            const inspectionReport = {
                overall_result: result.value,
                checklist: checklist,
                discrepancies: discrepancies,
                recommendations: recommendations,
                samples_required: samplesRequired,
                lab_test: labTest,
                photos: photos
            };

            // Toggle submit button loading state
            const submitBtn = document.querySelector('.btn-submit');
            const oldHtml = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<i class="ri-loader-4-line animate-spin"></i> Validating...`;

            try {
                console.log("STEP 2: Starting validation process");
                const oldStatus = application?.status || 'unknown';

                // AI validate the inspection report
                console.log("STEP 3: Calling validateInspectionReport");
                const validationResults = await validateInspectionReport(appId, inspectionReport);
                console.log("STEP 3.1: Validation results received", validationResults);

                // Update application status & route based on validation results
                console.log("STEP 4: Calling updateApplicationStatusAfterInspection");
                const statusUpdate = await updateApplicationStatusAfterInspection(appId, validationResults, inspectionReport);
                console.log("STEP 4.1: Status update received", statusUpdate);

                // Log inspection activity
                await logInspectionActivity(
                    'inspection_completed',
                    appId,
                    'Physical inspection report submitted with AI validation',
                    { validation_score: validationResults.validation_score, validation_passed: validationResults.validation_passed }
                );

                // Log audit action
                await logAuditAction(
                    'UPDATE',
                    'applications',
                    appId,
                    { status: oldStatus },
                    { status: statusUpdate.newStatus, inspection_report: inspectionReport }
                );

                // Send notification based on routing decision
                console.log("STEP 5: Checking if escalation needed, newStatus:", statusUpdate.newStatus);
                if (application?.user_id) {
                    if (statusUpdate.newStatus === 'escalated') {
                        console.log("STEP 6: ESCALATION TRIGGERED - Calling createEscalationCase");
                        console.log("STEP 6.1: Escalation payload", {
                            applicationId: appId,
                            reason: statusUpdate.message,
                            priority: 'high',
                            applicationStatus: 'pending_review',
                            notes: 'Escalated from inspection due to AI validation failure'
                        });
                        // Create escalation case in escalated_cases table
                        const escalationResult = await createEscalationCase(appId, {
                            reason: statusUpdate.message,
                            priority: 'high',
                            applicationStatus: 'pending_review',
                            notes: 'Escalated from inspection due to AI validation failure'
                        });
                        console.log("STEP 7: createEscalationCase result", escalationResult);
                        await sendInspectionEscalatedNotification(application.user_id, appId, statusUpdate.message);
                    } else {
                        console.log("STEP 6: No escalation - sending completion notification");
                        await sendInspectionCompletedNotification(application.user_id, appId);
                    }
                }

                // Prepare result notification details
                let detailsMsg = `=== AI Report Validation Result ===\n`;
                detailsMsg += `Validation Score: ${validationResults.validation_score}/100\n`;
                detailsMsg += `Validation Status: ${validationResults.validation_passed ? 'PASSED ✓' : 'FAILED ✗'}\n\n`;

                if (validationResults.errors.length > 0) {
                    detailsMsg += `Inconsistencies Detected:\n` + validationResults.errors.map(e => `- ${e}`).join('\n') + `\n\n`;
                }

                if (validationResults.warnings.length > 0) {
                    detailsMsg += `Warnings:\n` + validationResults.warnings.map(w => `- ${w}`).join('\n') + `\n\n`;
                }

                detailsMsg += `Routing Decision:\n${statusUpdate.message}`;

                console.log('Inspection report submitted:', detailsMsg);

                // Redirect to Queue
                window.location.href = 'inspection-queue.html';
            } catch (err) {
                console.error('Submission failed:', err.message);
                submitBtn.disabled = false;
                submitBtn.innerHTML = oldHtml;
            }
        }

        // Bind functions to window context for inline HTML attributes
        window.switchTab = switchTab;
        window.openCameraModal = openCameraModal;
        window.closeCameraModal = closeCameraModal;
        window.capturePhoto = capturePhoto;
        window.handlePhotoUpload = handlePhotoUpload;
        window.removePhoto = removePhoto;
        window.submitInspectionReport = submitInspectionReport;
        window.handleSignOut = handleSignOut;

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeCameraModal();
            }
        });

        document.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>




